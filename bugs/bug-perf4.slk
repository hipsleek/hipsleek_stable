data node { int val ; node next }.
 
pred lseg<p> == self = p 
or self::node<_,r> * r::lseg<p> & self!=p inv true.

checkentail x::node<_,r> * r::lseg<p> & r!=p |- x!=r.
// Valid
//  old note: used to return may-mismatch (cause: x!=null |- x!=r); baga info not in r::lseg<p>.
//  now returns correctly with --eps; default mode also returns correctly.
